skill "pr-summariser" {
    input {
        repo: string
        pr_number: int
    }

    output {
        summary: string
        files_changed: int
    }

    tools {
        require mcp("github") {
            pr_diff(repo: string, pr: int) -> string
        }
    }

    body {
        context(priority: 100) {
            """
            Fetch the diff for a pull request and produce a concise
            summary of the changes, including the number of files changed.
            """
        }

        step fetch {
            use pr_diff(repo: input.repo, pr: input.pr_number)

            context(priority: 90) {
                """
                Retrieve the PR diff using the github tool.
                """
            }
        }

        step summarise {
            requires fetch
            emit output

            context {
                """
                Parse the diff output. Count the distinct files changed.
                Write a human-readable summary of what the PR does.
                """
            }
        }
    }

    tests {
        test "summarises mocked PR" {
            given {
                repo: "acme/widget"
                pr_number: 42
            }
            mock github {
                pr_diff(repo: "acme/widget", pr: 42) -> "diff --git a/src/main.rs b/src/main.rs\n--- a/src/main.rs\n+++ b/src/main.rs\n@@ -1,3 +1,5 @@\n fn main() {\n+    println!(\"hello\");\n+    setup();\n }\ndiff --git a/src/lib.rs b/src/lib.rs\n--- a/src/lib.rs\n+++ b/src/lib.rs\n@@ -1 +1,3 @@\n+pub fn setup() {}\n"
            }
            expect {
                output.files_changed: equals(2)
                output.summary: contains("main")
            }
        }
    }
}
